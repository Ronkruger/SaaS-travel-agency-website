APP_NAME=DiscoverGRP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-railway-url.railway.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=discovergrp
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_REDIRECT_URI=${APP_URL}/auth/auth0/callback

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@discovergrp.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Stripe Payment Gateway (optional)
STRIPE_KEY=
STRIPE_SECRET=

# AI Provider — DIY Tour Builder (OpenAI-compatible endpoint)
# Groq (free): https://console.groq.com → create API key
AI_BASE_URL=https://api.groq.com/openai
OPENAI_API_KEY=gsk_...
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_TIMEOUT=30
# To switch to OpenAI: AI_BASE_URL=https://api.openai.com  OPENAI_MODEL=gpt-4o
# To use Ollama locally: AI_BASE_URL=http://localhost:11434/v1  OPENAI_MODEL=llama3  OPENAI_API_KEY=ollama

# Mapbox — DIY Tour Builder Map
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12

# DIY Tour session expiry (days)
DIY_SESSION_EXPIRY_DAYS=30

# ──────────────────────────────────────────────
# SaaS Multi-tenancy
# ──────────────────────────────────────────────

# The root domain for the platform (agencies get {id}.APP_DOMAIN subdomains)
APP_DOMAIN=toursaas.com

# Comma-separated list of central (non-tenant) domains
CENTRAL_DOMAINS=toursaas.com,www.toursaas.com

# Platform superadmin seed credentials
PLATFORM_ADMIN_NAME="Platform Admin"
PLATFORM_ADMIN_EMAIL=admin@toursaas.com
PLATFORM_ADMIN_PASSWORD=changeme_immediately

# Stripe — platform-level subscription billing
STRIPE_WEBHOOK_SECRET=

# Default trial length (days) for new tenants
TENANT_TRIAL_DAYS=14
